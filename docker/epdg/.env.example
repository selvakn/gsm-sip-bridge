# Copy to .env and edit as needed. All values have working defaults for
# Vodafone (Vi) India on the EC200U at /dev/ttyUSB6; override only if required.

# Operator identity (used to build the ePDG FQDN and the EAP-AKA NAI realm).
MCC=404
MNC=043

# IMS APN — gives us the P-CSCF address in the IKE config payload.
APN=ims

# Modem AT port used for AT+CIMI (IMSI) and AT+CSIM (EAP-AKA against the SIM).
MODEM_PORT=/dev/ttyUSB6

# ePDG address. Leave EPDG_IP unset to resolve
# epdg.epc.mnc043.mcc404.pub.3gppnetwork.org via public DNS (works for Vi India).
# Set it explicitly to bypass DNS, e.g. EPDG_IP=203.88.11.33
#EPDG_IP=
#EPDG_FQDN=epdg.epc.mnc043.mcc404.pub.3gppnetwork.org

# Network namespace the dialer creates for the tunnel interface.
NETNS=ims

# Source IP for IKE/IPsec (auto-detected if unset).
#SRC_ADDR=

# Keepalive ping interval (seconds) to keep the idle tunnel alive.
KEEPALIVE_INTERVAL=20
