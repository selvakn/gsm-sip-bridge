# Secrets only. All other configuration (VoWiFi/ePDG tunnel engine, MCC/MNC,
# metrics port, etc.) lives in config.toml — see config.toml.example's
# [vowifi] section and docs/configuration.md. config.toml may reference a
# secret from here via "env:VAR_NAME" on any string field (e.g. SIP
# credentials, the Discord webhook URL below).

# SIP credentials
SIP_PASSWORD=changeme

# Discord webhook for SMS forwarding (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Grafana admin password (docker-compose only — the grafana/grafana image
# has no knowledge of our config.toml, so this one can't move there)
GRAFANA_ADMIN_PASSWORD=admin
