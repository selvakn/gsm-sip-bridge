# SIP credentials
SIP_PASSWORD=changeme

# Discord webhook for SMS forwarding (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Metrics server port override (default: 9091)
# METRICS_PORT=9091

# Grafana admin password (docker-compose only)
GRAFANA_ADMIN_PASSWORD=admin

# VoWiFi/ePDG tunnel engine (only used when [vowifi].enabled = true in
# config.toml — see docker/entrypoint.sh). "swu" is the original SWu-IKEv2
# Python dialer; "strongswan" is the new engine (specs/012-strongswan-epdg)
# with proper IKE rekeying/re-auth/DPD/MOBIKE and a network namespace that
# survives reconnects. Switching engines is a restart, no rebuild.
#
# Default stays "swu" until strongSwan's live-carrier proving criteria
# (spec.md Success Criteria SC-001..SC-004: 24h unattended uptime through
# a rekey, outage recovery, both-carrier EAP-AKA) are recorded as passed —
# see specs/012-strongswan-epdg/quickstart.md. Flip to "strongswan"
# explicitly to test it in the meantime.
# TUNNEL_ENGINE=swu
