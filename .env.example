# SIP credentials
SIP_PASSWORD=changeme

# Discord webhook for SMS forwarding (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Metrics server port override (default: 9091)
# METRICS_PORT=9091

# Grafana admin password (docker-compose only)
GRAFANA_ADMIN_PASSWORD=admin

# VoWiFi/ePDG tunnel engine (only used when [vowifi].enabled = true in
# config.toml — see docker/entrypoint.sh). "strongswan" (the default) has
# proper IKE rekeying/re-auth/DPD/MOBIKE and a network namespace that
# survives reconnects (specs/012-strongswan-epdg) — live-verified against
# Airtel India (outage recovery, engine-switch, and EAP-AKA all passed;
# see specs/012-strongswan-epdg/tasks.md). "swu" is the original SWu-IKEv2
# Python dialer, kept as an explicit fallback: the 24h unattended-uptime
# soak (SC-001) and the Vi-carrier half of EAP-AKA (SC-004) are still
# outstanding. Switching engines is a restart, no rebuild.
# TUNNEL_ENGINE=strongswan
